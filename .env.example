# Copia este archivo a .env.local y cambia los valores.
# .env.local NUNCA se sube a git (ya está ignorado).

# Contraseña para entrar al panel oculto /panel-selveo
ADMIN_PASSWORD=selveo2026

# Frase secreta cualquiera, solo se usa internamente para firmar la sesión del panel.
# Cámbiala por cualquier texto largo y aleatorio.
SESSION_SECRET=cambia-esto-por-un-texto-largo-y-aleatorio

# Solo es necesario en producción (Vercel) para que subir fotos y guardar
# propiedades funcione. Se crea automáticamente al conectar un "Blob Store"
# en el dashboard de Vercel. En local NO hace falta: se usa el disco duro.
# BLOB_READ_WRITE_TOKEN=
